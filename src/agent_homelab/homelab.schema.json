{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.net/agent-homelab/schema/v1",
  "title": "Agent Homelab inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "site", "nodes", "services"],
  "properties": {
    "schema_version": {"const": 1},
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "timezone"],
      "properties": {
        "domain": {"type": "string", "minLength": 1},
        "timezone": {"type": "string", "minLength": 1},
        "certificate_resolver": {"type": "string", "default": "letsencrypt"},
        "authelia": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {"type": "string", "format": "uri"},
            "session_secret_ref": {"$ref": "#/$defs/secretRef"},
            "storage_encryption_key_ref": {"$ref": "#/$defs/secretRef"}
          }
        }
      }
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/node"}
    },
    "services": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/service"}
    }
  },
  "$defs": {
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env"],
      "properties": {"env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}}
    },
    "connect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {"type": "string", "minLength": 1},
        "ssh_alias": {"type": "string", "minLength": 1}
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {"enum": ["local", "ssh"]},
        "root": {"type": "string", "minLength": 1},
        "state_root": {"type": "string", "minLength": 1},
        "validate_command": {"type": "array", "items": {"type": "string"}},
        "reload_command": {"type": "array", "items": {"type": "string"}}
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "connect"],
      "properties": {
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["service_host", "edge_gateway"]}
        },
        "connect": {"$ref": "#/$defs/connect"},
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {"scheme": {"enum": ["http", "https"]}, "port": {"type": "integer", "minimum": 1, "maximum": 65535}}
        },
        "deploy": {"$ref": "#/$defs/deploy"}
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "scheme", "host", "port", "port_source"],
      "properties": {
        "node": {"type": "string", "minLength": 1},
        "scheme": {"enum": ["http", "https"]},
        "host": {"type": "string", "minLength": 1},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "port_source": {"type": "string", "minLength": 1},
        "allow_ephemeral_port": {"type": "boolean", "default": false}
      }
    },
    "pathRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path_prefix", "upstream"],
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "path_prefix": {"type": "string", "pattern": "^/"},
        "upstream": {"$ref": "#/$defs/upstream"},
        "middlewares": {"type": "array", "items": {"type": "string"}}
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upstream"],
      "properties": {
        "upstream": {"$ref": "#/$defs/upstream"},
        "forward_auth": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["address"],
            "properties": {
              "address": {"type": "string", "format": "uri"},
              "trust_forward_header": {"type": "boolean", "default": true},
              "auth_response_headers": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "local": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {"enabled": {"type": "boolean"}, "hostname": {"type": "string"}}
        },
        "public": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": {"type": "boolean"},
            "hostname": {"type": "string"},
            "edge_node": {"type": "string"},
            "entrypoint": {"type": "string", "default": "websecure"},
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "required": ["provider", "policy"],
              "properties": {
                "provider": {"const": "authelia"},
                "policy": {"enum": ["one_factor", "two_factor", "bypass", "deny"]}
              }
            }
          }
        },
        "path_routes": {"type": "array", "items": {"$ref": "#/$defs/pathRoute"}}
      }
    }
  }
}
